pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Obteniendo código de GitHub...'
                checkout scm
            }
        }
        stage('Build') {
            steps {
                echo 'Compilando Spring Boot...'
                // Usa el wrapper de Maven que viene con Spring Boot
                sh './mvnw clean package -DskipTests'
            }
        }
        stage('Test') {
            steps {
                echo 'Ejecutando pruebas unitarias...'
                sh './mvnw test'
            }
        }
        stage('SonarQube Analysis') {
            steps {
                echo 'Auditando la calidad del código fuente...'
                // Esta instrucción envuelve el comando y le inyecta la URL y el Token automáticamente
                withSonarQubeEnv('SonarQube-Local') {
                    sh './mvnw sonar:sonar'
                }
            }
        }
        stage('Docker Build') {
            steps {
                echo 'Construyendo la imagen Docker...'
                // Gracias al túnel de Docker Desktop, esto se ejecutará en el motor de tu Mac
                sh 'docker build -t mi-api-backend:latest .'
            }
        }
        stage('Security Scan (Trivy)') {
            steps {
                echo 'Buscando vulnerabilidades CRÍTICAS y ALTAS en la imagen...'
                // 1. Ejecutamos Trivy usando la plantilla HTML integrada y guardamos la salida en trivy-report.html
                // Usamos 'catchError' para que el pipeline no se rompa de inmediato si hay vulnerabilidades,
                // permitiendo que el reporte se guarde primero.
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    sh 'docker run --rm -v /var/run/docker.sock:/var/run/docker.sock aquasec/trivy image --format template --template "@/contrib/html.tpl" --exit-code 1 --severity HIGH,CRITICAL mi-api-backend:latest > trivy-report.html'
                }
                
                // 2. Le decimos a Jenkins que tome ese archivo y lo ponga disponible en la interfaz
                archiveArtifacts artifacts: 'trivy-report.html', allowEmptyArchive: true
            }
        }
        stage('Deploy Local') {
            steps {
                echo 'Desplegando la API localmente...'
                // El comando '|| true' evita que el pipeline falle si es la primera vez y el contenedor no existe
                sh '''
                    docker stop mi-api-backend-container || true
                    docker rm mi-api-backend-container || true
                    docker run -d -p 8081:8080 --name mi-api-backend-container mi-api-backend:latest
                '''
            }
        }
    }
}